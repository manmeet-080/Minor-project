    {
      "name": "Fees",
      "description": "Fee management: create records, record payments, check balances.",
      "item": [
        {
          "name": "List Fees",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/fees?hostelId={{hostelId}}&page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["fees"],
              "query": [
                { "key": "hostelId", "value": "{{hostelId}}" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "studentId", "value": "", "disabled": true },
                { "key": "status", "value": "", "disabled": true, "description": "PENDING | PAID | OVERDUE | WAIVED | PARTIALLY_PAID" },
                { "key": "type", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Fee by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/fees/{{feeId}}"
          }
        },
        {
          "name": "Get Student Balance",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/fees/student/{{studentProfileId}}/balance"
          }
        },
        {
          "name": "Create Fee Record",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('feeId', pm.response.json().data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/fees",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": \"{{studentProfileId}}\",\n  \"hostelId\": \"{{hostelId}}\",\n  \"type\": \"HOSTEL_FEE\",\n  \"amount\": 25000,\n  \"dueDate\": \"2026-05-15\",\n  \"remarks\": \"Semester 2 hostel fee\"\n}"
            }
          }
        },
        {
          "name": "Record Payment",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/fees/{{feeId}}/pay",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paidAmount\": 25000,\n  \"paymentMethod\": \"UPI\",\n  \"transactionId\": \"TXN-2026-001\"\n}"
            }
          }
        },
        {
          "name": "Waive Fee",
          "request": {
