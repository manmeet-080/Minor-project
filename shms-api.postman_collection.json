              "raw": "{\n  \"name\": \"Nehru Hostel Updated\",\n  \"address\": \"New Address\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Students",
      "description": "Student registration, approval, and management.",
      "item": [
        {
          "name": "Apply (Register New Student)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json().data;",
                  "  if (data.studentProfile) pm.collectionVariables.set('studentProfileId', data.studentProfile.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/students/apply",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newstudent@student.edu\",\n  \"password\": \"student123\",\n  \"name\": \"New Student\",\n  \"phone\": \"9876543299\",\n  \"rollNumber\": \"CS2025001\",\n  \"department\": \"CS\",\n  \"year\": 1,\n  \"gender\": \"MALE\",\n  \"parentName\": \"Parent Name\",\n  \"parentPhone\": \"9876543200\",\n  \"permanentAddress\": \"123 Main Street, City, State\",\n  \"hostelId\": \"{{hostelId}}\"\n}"
            }
          }
        },
        {
          "name": "List Students",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/students?page=1&limit=20&status=APPROVED",
              "host": ["{{baseUrl}}"],
              "path": ["students"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "status", "value": "APPROVED", "description": "PENDING | APPROVED | REJECTED | CHECKED_OUT | GRADUATED" },
                { "key": "search", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Student by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/students/{{studentProfileId}}"
          }
        },
        {
          "name": "Update Student",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/students/{{studentProfileId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"department\": \"ECE\",\n  \"year\": 3\n}"
            }
          }
        },
        {
          "name": "Approve Student",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/students/{{studentProfileId}}/approve"
          }
        },
        {
          "name": "Reject Student",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/students/{{studentProfileId}}/reject"
          }
        },
        {
          "name": "Checkout Student",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/students/{{studentProfileId}}/checkout"
          }
        }
      ]
    },
    {
      "name": "Rooms & Beds",
      "description": "Room management, bed allocation, and block configuration.",
      "item": [
        {
          "name": "List Rooms",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/rooms?hostelId={{hostelId}}&page=1&limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["rooms"],
              "query": [
                { "key": "hostelId", "value": "{{hostelId}}" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "50" },
                { "key": "blockId", "value": "", "disabled": true },
                { "key": "status", "value": "", "disabled": true, "description": "AVAILABLE | OCCUPIED | PARTIALLY_OCCUPIED | UNDER_MAINTENANCE" },
                { "key": "floor", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Room by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const room = pm.response.json().data;",
                  "  if (room.beds && room.beds.length > 0) {",
                  "    pm.collectionVariables.set('bedId', room.beds[0].id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/rooms/{{roomId}}"
          }
        },
        {
          "name": "Create Room",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('roomId', pm.response.json().data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/rooms",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roomNumber\": \"A501\",\n  \"blockId\": \"{{blockId}}\",\n  \"floor\": 5,\n  \"type\": \"DOUBLE\",\n  \"capacity\": 2,\n  \"amenities\": [\"WiFi\", \"Fan\", \"Desk\"]\n}"
            }
          }
        },
        {
          "name": "Update Room",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/rooms/{{roomId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"UNDER_MAINTENANCE\"\n}"
            }
          }
        },
        {
          "name": "Allocate Bed to Student",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/rooms/allocate",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bedId\": \"{{bedId}}\",\n  \"studentId\": \"{{studentProfileId}}\"\n}"
            }
          }
        },
        {
          "name": "Vacate Bed",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/rooms/beds/{{bedId}}/vacate"
          }
        },
        {
          "name": "List Blocks (by Hostel)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const blocks = pm.response.json().data;",
                  "  if (blocks && blocks.length > 0) {",
                  "    pm.collectionVariables.set('blockId', blocks[0].id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/rooms/blocks/{{hostelId}}"
          }
        },
        {
          "name": "Create Block",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('blockId', pm.response.json().data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/rooms/blocks",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Block C\",\n  \"hostelId\": \"{{hostelId}}\",\n  \"floors\": 3\n}"
            }
          }
        }
      ]
    },
