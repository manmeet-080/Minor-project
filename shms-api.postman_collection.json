{
  "info": {
    "name": "SHMS - Smart Hostel Management System",
    "description": "Complete API collection for SHMS. Set the `baseUrl` variable to your server address.\n\n**Quick start:**\n1. Run the \"Login (Admin)\" request\n2. The access token is automatically saved to the `accessToken` variable\n3. All authenticated requests use this token via Bearer auth\n\n**Demo credentials:**\n- Admin: admin@shms.edu / admin123\n- Warden: warden@shms.edu / warden123\n- Staff: staff@shms.edu / staff123\n- Student: arun@student.edu / student123",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "hostelId", "value": "" },
    { "key": "studentProfileId", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "complaintId", "value": "" },
    { "key": "feeId", "value": "" },
    { "key": "gatePassId", "value": "" },
    { "key": "visitorId", "value": "" },
    { "key": "roomId", "value": "" },
    { "key": "bedId", "value": "" },
    { "key": "blockId", "value": "" },
    { "key": "bookingId", "value": "" },
    { "key": "notificationId", "value": "" },
    { "key": "staffUserId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/../health", "host": ["{{baseUrl}}"], "path": ["..", "health"] },
            "auth": { "type": "noauth" }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "description": "Authentication & profile management. Login requests auto-save tokens to collection variables.",
      "item": [
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json().data;",
                  "  pm.collectionVariables.set('accessToken', data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', data.refreshToken);",
                  "  pm.collectionVariables.set('userId', data.user.id);",
                  "  pm.collectionVariables.set('hostelId', data.user.hostelId || '');",
                  "  pm.test('Login successful', () => pm.expect(pm.response.json().success).to.be.true);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@shms.edu\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Login (Student)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json().data;",
                  "  pm.collectionVariables.set('accessToken', data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', data.refreshToken);",
                  "  pm.collectionVariables.set('userId', data.user.id);",
                  "  pm.collectionVariables.set('hostelId', data.user.hostelId || '');",
                  "  if (data.user.studentProfile) {",
                  "    pm.collectionVariables.set('studentProfileId', data.user.studentProfile.id);",
                  "  }",
                  "  pm.test('Login successful', () => pm.expect(pm.response.json().success).to.be.true);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"arun@student.edu\",\n  \"password\": \"student123\"\n}"
            }
          }
        },
        {
          "name": "Login (Staff)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json().data;",
                  "  pm.collectionVariables.set('accessToken', data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', data.refreshToken);",
                  "  pm.collectionVariables.set('userId', data.user.id);",
                  "  pm.collectionVariables.set('staffUserId', data.user.id);",
                  "  pm.collectionVariables.set('hostelId', data.user.hostelId || '');",
                  "  pm.test('Login successful', () => pm.expect(pm.response.json().success).to.be.true);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"staff@shms.edu\",\n  \"password\": \"staff123\"\n}"
            }
          }
        },
        {
          "name": "Login (Warden)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json().data;",
                  "  pm.collectionVariables.set('accessToken', data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', data.refreshToken);",
                  "  pm.collectionVariables.set('userId', data.user.id);",
                  "  pm.collectionVariables.set('hostelId', data.user.hostelId || '');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"warden@shms.edu\",\n  \"password\": \"warden123\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json().data;",
                  "  pm.collectionVariables.set('accessToken', data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Get Me (Profile)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/auth/me",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\",\n  \"phone\": \"9999999999\"\n}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/change-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"admin123\",\n  \"newPassword\": \"newpassword123\"\n}"
            }
          }
        },
        {
          "name": "Get Sessions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/sessions"
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/forgot-password",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@shms.edu\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/reset-password",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"PASTE_RESET_TOKEN_HERE\",\n  \"password\": \"newpassword123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "description": "User listing (admin only). Used to fetch staff members for complaint assignment.",
      "item": [
        {
          "name": "List Users (by role & hostel)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users?hostelId={{hostelId}}&role=STAFF",
              "host": ["{{baseUrl}}"],
              "path": ["users"],
              "query": [
                { "key": "hostelId", "value": "{{hostelId}}" },
                { "key": "role", "value": "STAFF", "description": "ADMIN | WARDEN | STAFF | STUDENT" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Hostels",
      "description": "Hostel configuration.",
      "item": [
        {
          "name": "Get Hostel Details",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/hostels/{{hostelId}}"
          }
        },
        {
          "name": "Update Hostel",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/hostels/{{hostelId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
